# MetalDrummerGear Environment Variables
# Copy this file to .env and fill in your values
# For Vercel, add these in the project settings

# ============================================
# NEWSLETTER SUBSCRIBER NOTIFICATION (Telegram)
# ============================================
# Each new newsletter subscription pings a Telegram bot with the subscriber's
# email (no third-party email provider). Set BOTH to receive the pings — these
# are the same bot/chat the daily digest and watchdog use, but they must be
# added to Vercel's env (the serverless function can't read GitHub secrets).
TELEGRAM_BOT_TOKEN=123456789:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789

# ============================================
# VERCEL KV (Optional)
# ============================================
# Used for persistent subscriber storage and rate limiting
# If not configured, falls back to in-memory storage (resets on redeploy)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ============================================
# NEWS AGGREGATION (Issue #512)
# ============================================
# CRON_SECRET: Vercel automatically sends this with cron job requests
# Set this in Vercel dashboard or generate with: openssl rand -hex 32
CRON_SECRET=

# ADMIN_KEY: Used for manual news refresh via POST /api/news/refresh
# Send this in X-Admin-Key header
# Generate with: openssl rand -hex 32
ADMIN_KEY=
