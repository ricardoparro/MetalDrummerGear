# MetalDrummerGear Environment Variables
# Copy this file to .env and fill in your values
# For Vercel, add these in the project settings

# ============================================
# NEWSLETTER EMAIL (Resend)
# ============================================
# Required for sending welcome emails on newsletter subscription
# Get your API key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Optional: Custom sender email (requires verified domain in Resend)
# If not set, uses Resend sandbox (onboarding@resend.dev) - works for testing only
# Format: "Name <email@domain.com>"
RESEND_FROM_EMAIL=MetalForge <noreply@metalforge.io>

# ============================================
# VERCEL KV (Optional)
# ============================================
# Used for persistent subscriber storage and rate limiting
# If not configured, falls back to in-memory storage (resets on redeploy)
KV_REST_API_URL=
KV_REST_API_TOKEN=
