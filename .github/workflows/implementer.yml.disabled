name: Implementer (Ralph)

# DISABLED 2026-06-04 — Ricardo runs Ralph locally via .ralph/. Re-enable by
# renaming back to implementer.yml. See commit history for original push.

on:
  issues:
    types: [labeled]
  schedule:
    # Safety net: every 30 min in case a labeled event was missed
    - cron: '*/30 * * * *'
  workflow_dispatch:
    inputs:
      issue_number:
        description: Specific issue number to pick up (optional)
        required: false

permissions:
  contents: write
  issues: write
  pull-requests: write

# Serialize Ralph runs so two PRs don't race on the same files
concurrency:
  group: implementer
  cancel-in-progress: false

jobs:
  pick-and-implement:
    runs-on: ubuntu-latest
    timeout-minutes: 60
    # Skip on labeled trigger if it wasn't the ai-fix label
    if: >
      github.event_name != 'issues' ||
      github.event.label.name == 'ai-fix'
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0
          token: ${{ secrets.GITHUB_TOKEN }}

      - uses: actions/setup-node@v4
        with:
          node-version: '20'
          cache: 'npm'

      - name: Install Claude Code CLI
        run: npm install -g @anthropic-ai/claude-code

      - name: Configure git
        run: |
          git config user.name "ralph-agent[bot]"
          git config user.email "ralph-agent@users.noreply.github.com"

      - name: Pick next eligible issue
        id: pick
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
          MANUAL_ISSUE: ${{ inputs.issue_number }}
          EVENT_ISSUE: ${{ github.event.issue.number }}
        run: |
          set -e
          # Priority: explicit dispatch input > event-triggered issue > first eligible from queue
          if [ -n "$MANUAL_ISSUE" ]; then
            ISSUE_NUM="$MANUAL_ISSUE"
          elif [ "${{ github.event_name }}" = "issues" ]; then
            ISSUE_NUM="$EVENT_ISSUE"
          else
            ISSUE_NUM=$(gh issue list \
              --repo "${{ github.repository }}" \
              --label ai-fix --state open --limit 100 \
              --json number,labels \
              --jq '[.[] | select(.labels | map(.name) | (index("in-progress") | not) and (index("human-founder") | not))] | sort_by(.number) | .[0].number // ""')
          fi

          if [ -z "$ISSUE_NUM" ] || [ "$ISSUE_NUM" = "null" ]; then
            echo "No eligible ai-fix issue. Exiting."
            echo "skip=true" >> "$GITHUB_OUTPUT"
            exit 0
          fi

          # Validate: issue exists, is open, has ai-fix, no in-progress
          STATE=$(gh issue view "$ISSUE_NUM" --repo "${{ github.repository }}" --json state,labels)
          OPEN=$(echo "$STATE" | jq -r '.state')
          LABELS=$(echo "$STATE" | jq -r '.labels | map(.name) | join(",")')

          if [ "$OPEN" != "OPEN" ] || ! echo ",$LABELS," | grep -q ",ai-fix,"; then
            echo "Issue #$ISSUE_NUM not eligible (state=$OPEN labels=$LABELS). Skipping."
            echo "skip=true" >> "$GITHUB_OUTPUT"
            exit 0
          fi

          if echo ",$LABELS," | grep -q ",in-progress,"; then
            echo "Issue #$ISSUE_NUM already in-progress. Skipping."
            echo "skip=true" >> "$GITHUB_OUTPUT"
            exit 0
          fi

          echo "issue_num=$ISSUE_NUM" >> "$GITHUB_OUTPUT"
          echo "skip=false" >> "$GITHUB_OUTPUT"

      - name: Claim issue (mutex via in-progress label)
        if: steps.pick.outputs.skip != 'true'
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          gh issue edit "${{ steps.pick.outputs.issue_num }}" \
            --repo "${{ github.repository }}" \
            --add-label in-progress

      - name: Create branch
        if: steps.pick.outputs.skip != 'true'
        id: branch
        run: |
          BRANCH="ralph/issue-${{ steps.pick.outputs.issue_num }}-$(date -u +%Y%m%d%H%M)"
          git checkout -b "$BRANCH"
          echo "branch=$BRANCH" >> "$GITHUB_OUTPUT"

      - name: Run Ralph on the issue
        if: steps.pick.outputs.skip != 'true'
        env:
          ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
          ISSUE_NUM: ${{ steps.pick.outputs.issue_num }}
        run: |
          set -e
          mkdir -p .agents/ralph-runs

          # Pull issue title + body
          gh issue view "$ISSUE_NUM" --repo "${{ github.repository }}" \
            --json title,body \
            > .agents/ralph-runs/issue-${ISSUE_NUM}.json

          ISSUE_TITLE=$(jq -r .title .agents/ralph-runs/issue-${ISSUE_NUM}.json)
          ISSUE_BODY=$(jq -r .body .agents/ralph-runs/issue-${ISSUE_NUM}.json)

          # Build the task prompt by substituting into .ralph/PROMPT.md template
          {
            echo "# Task"
            echo
            echo "Fix GitHub issue #${ISSUE_NUM}: ${ISSUE_TITLE}"
            echo
            echo "${ISSUE_BODY}"
            echo
            echo "---"
            echo
            cat .ralph/AGENT.md
            echo
            echo "---"
            echo
            echo "## Instructions"
            echo
            echo "1. Read the issue carefully. If the Action section already specifies files, follow it."
            echo "2. Make minimal, focused changes. Do NOT refactor unrelated code."
            echo "3. Validate: \`node --check\` any .js/.cjs you touched, run lint/tests if configured."
            echo "4. Commit with message: \"fix: #${ISSUE_NUM} <one-line summary>\""
            echo "5. Do NOT push or open a PR — the workflow handles that after you finish."
            echo "6. If the issue is ambiguous, blocked on a human decision, or violates a guardrail,"
            echo "   stop and output a single line: NEEDS_HUMAN: <reason>"
            echo "   The workflow will see that and leave a comment instead of opening a PR."
            echo
            echo "Output a 5-line summary when done: problem, files changed, fix, validation, follow-ups."
          } > /tmp/ralph-prompt.md

          # Run Ralph with full permission bypass (sandbox is the VM, not the user's machine)
          cat /tmp/ralph-prompt.md | claude --print --dangerously-skip-permissions \
            2>&1 | tee .agents/ralph-runs/issue-${ISSUE_NUM}.log

      - name: Detect NEEDS_HUMAN signal
        if: steps.pick.outputs.skip != 'true'
        id: human_check
        env:
          ISSUE_NUM: ${{ steps.pick.outputs.issue_num }}
        run: |
          if grep -q "^NEEDS_HUMAN:" ".agents/ralph-runs/issue-${ISSUE_NUM}.log"; then
            REASON=$(grep "^NEEDS_HUMAN:" ".agents/ralph-runs/issue-${ISSUE_NUM}.log" | head -1 | sed 's/^NEEDS_HUMAN: *//')
            echo "needs_human=true" >> "$GITHUB_OUTPUT"
            echo "reason=$REASON" >> "$GITHUB_OUTPUT"
          else
            echo "needs_human=false" >> "$GITHUB_OUTPUT"
          fi

      - name: Hand back to human if Ralph bailed
        if: steps.pick.outputs.skip != 'true' && steps.human_check.outputs.needs_human == 'true'
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
          ISSUE_NUM: ${{ steps.pick.outputs.issue_num }}
          REASON: ${{ steps.human_check.outputs.reason }}
        run: |
          gh issue comment "$ISSUE_NUM" --repo "${{ github.repository }}" --body "🤖 Ralph stopped: $REASON

          See the run log artifact \`ralph-run-${{ github.run_id }}\` for full output."
          gh issue edit "$ISSUE_NUM" --repo "${{ github.repository }}" \
            --remove-label in-progress \
            --add-label needs-human

      - name: Push branch and open PR
        if: steps.pick.outputs.skip != 'true' && steps.human_check.outputs.needs_human != 'true'
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
          ISSUE_NUM: ${{ steps.pick.outputs.issue_num }}
          BRANCH: ${{ steps.branch.outputs.branch }}
        run: |
          # Ensure there's actually something to push
          if [ -z "$(git log origin/main..HEAD --oneline)" ]; then
            echo "Ralph made no commits. Leaving comment on issue and bailing."
            gh issue comment "$ISSUE_NUM" --repo "${{ github.repository }}" \
              --body "🤖 Ralph produced no commits this run. Run log: artifact \`ralph-run-${{ github.run_id }}\`."
            gh issue edit "$ISSUE_NUM" --repo "${{ github.repository }}" \
              --remove-label in-progress
            exit 0
          fi

          git push origin "$BRANCH"

          ISSUE_TITLE=$(jq -r .title .agents/ralph-runs/issue-${ISSUE_NUM}.json)
          gh pr create \
            --repo "${{ github.repository }}" \
            --base main \
            --head "$BRANCH" \
            --title "fix: #${ISSUE_NUM} ${ISSUE_TITLE}" \
            --body "Closes #${ISSUE_NUM}

          Implemented by Ralph (autonomous agent).
          Full run log: artifact \`ralph-run-${{ github.run_id }}\`.

          ---
          *Auto-opened by \`.github/workflows/implementer.yml\`.*"

          gh issue edit "$ISSUE_NUM" --repo "${{ github.repository }}" \
            --remove-label in-progress \
            --add-label pr-opened

      - name: Always clean up in-progress on failure
        if: failure() && steps.pick.outputs.skip != 'true'
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
          ISSUE_NUM: ${{ steps.pick.outputs.issue_num }}
        run: |
          gh issue edit "$ISSUE_NUM" --repo "${{ github.repository }}" \
            --remove-label in-progress || true
          gh issue comment "$ISSUE_NUM" --repo "${{ github.repository }}" \
            --body "🤖 Implementer workflow failed (run #${{ github.run_id }}). Removed in-progress label so the next run can retry." || true

      - name: Upload run log
        if: always() && steps.pick.outputs.skip != 'true'
        uses: actions/upload-artifact@v4
        with:
          name: ralph-run-${{ github.run_id }}
          path: .agents/ralph-runs/
          retention-days: 14
          if-no-files-found: ignore
