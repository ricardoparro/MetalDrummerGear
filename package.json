{
  "name": "metal-drummer-gear",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "postinstall": "patch-package",
    "frontend": "npm run start --workspace=packages/frontend",
    "backend": "npm run start --workspace=packages/backend",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "build": "npm run build --workspace=packages/frontend",
    "test": "npm run test --workspaces --if-present"
  },
  "dependencies": {
    "@vercel/edge": "^1.3.1",
    "@vercel/kv": "^3.0.0",
    "@vercel/og": "^0.11.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@google-analytics/data": "^6.1.0",
    "@playwright/test": "^1.58.1",
    "concurrently": "^8.2.2",
    "googleapis": "^173.0.0",
    "patch-package": "^8.0.1",
    "playwright": "^1.58.1"
  }
}
