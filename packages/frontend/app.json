{
  "expo": {
    "name": "MetalForge",
    "slug": "metalforge",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "MetalForge - Discover What Pro Metal Drummers Play",
      "shortName": "MetalForge",
      "description": "Explore the drum kits, cymbals, and gear used by legendary metal drummers. Discover what Lars Ulrich, Joey Jordison, Dave Lombardo and 50+ pro drummers play, compare setups, and find your perfect gear.",
      "themeColor": "#1a1a2e",
      "backgroundColor": "#1a1a2e"
    }
  }
}
