{
  "trailingSlash": false,
  "git": {
    "deploymentEnabled": {
      "main": false
    }
  },
  "ignoreCommand": "if [ \"$VERCEL_GIT_COMMIT_REF\" = \"main\" ] || [ -z \"$VERCEL_GIT_COMMIT_REF\" ]; then exit 1; else exit 0; fi",
  "crons": [
    {
      "path": "/api/cron/fetch-news",
      "schedule": "0 8 * * *"
    }
  ],
  "buildCommand": "bash scripts/build.sh",
  "outputDirectory": "packages/frontend/dist",
  "installCommand": "npm install && npx patch-package",
  "framework": null,
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Link",
          "value": "<https://metalforge.io>; rel=preconnect, <https://upload.wikimedia.org>; rel=preconnect; crossorigin, <https://i.ytimg.com>; rel=preconnect; crossorigin, </api/init>; rel=preload; as=fetch; crossorigin, </.well-known/api-catalog>; rel=\"api-catalog\", </llms.txt>; rel=\"service-doc\"; type=\"text/plain\", </llms/index.md>; rel=\"service-doc\"; type=\"text/markdown\", </sitemap.xml>; rel=\"sitemap\"; type=\"application/xml\""
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=3600, stale-while-revalidate=86400"
        },
        {
          "key": "Link",
          "value": "<https://metalforge.io>; rel=preconnect, <https://upload.wikimedia.org>; rel=preconnect; crossorigin, <https://i.ytimg.com>; rel=preconnect; crossorigin, </api/init>; rel=preload; as=fetch; crossorigin, </.well-known/api-catalog>; rel=\"api-catalog\", </llms.txt>; rel=\"service-doc\"; type=\"text/plain\", </llms/index.md>; rel=\"service-doc\"; type=\"text/markdown\", </sitemap.xml>; rel=\"sitemap\"; type=\"application/xml\""
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    },
    {
      "source": "/api/card/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, s-maxage=86400, stale-while-revalidate=604800"
        },
        {
          "key": "Content-Type",
          "value": "image/png"
        }
      ]
    },
    {
      "source": "/api/og/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, s-maxage=86400, stale-while-revalidate=604800"
        },
        {
          "key": "Content-Type",
          "value": "image/png"
        }
      ]
    },
    {
      "source": "/api/meta/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=3600, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/drummer/:slug",
      "headers": [
        {
          "key": "Vary",
          "value": "User-Agent"
        }
      ]
    },
    {
      "source": "/genre/:slug",
      "headers": [
        {
          "key": "Vary",
          "value": "User-Agent"
        }
      ]
    },
    {
      "source": "/genres",
      "headers": [
        {
          "key": "Vary",
          "value": "User-Agent"
        }
      ]
    },
    {
      "source": "/bands/:slug",
      "headers": [
        {
          "key": "Vary",
          "value": "User-Agent"
        }
      ]
    },
    {
