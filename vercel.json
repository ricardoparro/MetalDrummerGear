  "rewrites": [
    { "source": "/robots.txt", "destination": "/api/robots" },
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/video-sitemap.xml", "destination": "/api/video-sitemap" },
    { "source": "/.well-known/api-catalog", "destination": "/api/api-catalog" },
    { "source": "/facts", "destination": "/api/facts" },
    { "source": "/llms.txt", "destination": "/llms.txt" },
    { "source": "/llms-full.txt", "destination": "/llms-full.txt" },
    { "source": "/llms/index.md", "destination": "/llms/index.md" },
    { "source": "/api/card/:slug", "destination": "/api/card/[slug]?slug=:slug" },
    { "source": "/api/drummer/:id/markdown", "destination": "/api/drummer/[id]/markdown?id=:id" },
    { "source": "/api/drummers/:id", "destination": "/api/drummers/[id]?id=:id" },
    { "source": "/api/gear/category/:category", "destination": "/api/gear/category/[category]?category=:category" },
    { "source": "/api/gear/:id", "destination": "/api/gear/[id]?id=:id" },
    { "source": "/api/tier-list/:id", "destination": "/api/tier-list/[id]?id=:id" },
    { "source": "/gear-news/feed.xml", "destination": "/api/gear-news/feed" },
    { "source": "/embed/gallery", "destination": "/api/embed/gallery" },
    { "source": "/embed/:slug", "destination": "/api/embed/[slug]?slug=:slug" },
    { "source": "/api/embed/track", "destination": "/api/embed/track" },
    { "source": "/api/embed/stats", "destination": "/api/embed/stats" },
    { "source": "/api/gear/:slug/:category", "destination": "/api/gear/[slug]/[category]?slug=:slug&category=:category" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
